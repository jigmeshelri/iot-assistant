# PostgreSQL / TimescaleDB (local dev)
POSTGRES_USER=iot
POSTGRES_PASSWORD=iot_secret
POSTGRES_DB=iot_assistant

# Supabase Cloud
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<publishable-key>   # Settings → API → Project API keys
SUPABASE_SECRET_KEY=<secret-key>             # Settings → API → Project API keys
SUPABASE_JWT_SECRET=<jwt-secret>             # Settings → API → JWT Secret

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-...

# Frontend URL (usado por FastAPI para links de QR)
FRONTEND_URL=http://localhost:4321
