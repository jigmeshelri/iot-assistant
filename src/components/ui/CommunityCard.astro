---
/**
 * Community feed card. Used in both mobile (1 col) and desktop (3 col grid)
 * slots of /community.
 *
 * Avatar gradient + initials are derived deterministically from `user_id`
 * so each user gets a stable visual identity until project cover images
 * land in v2 (FUNCTIONAL_SPEC.md, "Won't Have v1").
 */
export interface Props {
  project: {
    id: string
    user_id: string
    title: string
    description: string | null
    project_type: string | null
    difficulty: string | null
    tags: string[] | null
    direct_fork_count: number
    created_at: string
    comments?: Array<{ count: number }>
  }
}

const { project: p } = Astro.props

// Static gradient palette — must be literal strings so Tailwind JIT picks them up.
const GRADIENTS = [
  'from-teal-400 to-teal-600',
  'from-violet-400 to-violet-600',
  'from-amber-400 to-amber-600',
  'from-rose-400 to-rose-600',
  'from-sky-400 to-sky-600',
  'from-fuchsia-400 to-fuchsia-600',
  'from-emerald-400 to-emerald-600',
  'from-indigo-400 to-indigo-600',
] as const

function hashString(s: string): number {
  let h = 0
  for (let i = 0; i < s.length; i++) h = ((h * 31) + s.charCodeAt(i)) | 0
  return Math.abs(h)
}

const gradient = GRADIENTS[hashString(p.user_id) % GRADIENTS.length]
const initials = p.user_id.slice(0, 2).toUpperCase()

function difficultyClass(d: string | null): string {
  if (d === 'beginner')     return 'bg-green-500/10 text-green-600 dark:text-green-400'
  if (d === 'intermediate') return 'bg-amber-500/10 text-amber-600 dark:text-amber-400'
  if (d === 'advanced')     return 'bg-rose-500/10 text-rose-600 dark:text-rose-400'
  return 'bg-slate-500/10 text-slate-500'
}

function timeAgo(iso: string): string {
  const ms = Date.now() - new Date(iso).getTime()
  const days = Math.floor(ms / 86_400_000)
  if (days < 1)  return 'hoy'
  if (days === 1) return 'ayer'
  if (days < 7)  return `hace ${days} días`
  if (days < 30) return `hace ${Math.floor(days / 7)} sem`
  if (days < 365) return `hace ${Math.floor(days / 30)} meses`
  return `hace ${Math.floor(days / 365)} años`
}

const commentCount = p.comments?.[0]?.count ?? 0
const visibleTags = (p.tags ?? []).slice(0, 3)
const hiddenTags = (p.tags?.length ?? 0) - visibleTags.length
---

<a
  href={`/community/${p.id}`}
  class="bg-white rounded-2xl p-4 flex flex-col gap-3 shadow-sm border border-slate-100 hover:border-teal-300 hover:shadow-md transition-all"
>
  <div class="flex items-start gap-3">
    <div class={`w-11 h-11 bg-gradient-to-br ${gradient} rounded-xl flex items-center justify-center flex-shrink-0 text-white font-bold text-sm`}>
      {initials}
    </div>
    <div class="flex-1 min-w-0">
      <h2 class="text-sm font-semibold text-slate-800 leading-tight">{p.title}</h2>
      <p class="text-xs text-slate-400 mt-0.5">
        Maker{p.project_type ? ` · ${p.project_type}` : ''}
      </p>
    </div>
  </div>

  {p.description && (
    <p class="text-xs text-slate-500 line-clamp-2 leading-relaxed">{p.description}</p>
  )}

  {(p.difficulty || visibleTags.length > 0) && (
    <div class="flex items-center gap-1.5 flex-wrap">
      {p.difficulty && (
        <span class={`text-[10px] px-2 py-0.5 rounded-full ${difficultyClass(p.difficulty)}`}>
          {p.difficulty}
        </span>
      )}
      {visibleTags.map(tag => (
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-teal-500/10 text-teal-600 dark:text-teal-400">
          {tag}
        </span>
      ))}
      {hiddenTags > 0 && (
        <span class="text-[10px] text-slate-400">+{hiddenTags}</span>
      )}
    </div>
  )}

  <div class="flex items-center gap-4 text-xs text-slate-400 pt-2 border-t border-slate-100">
    <span class="flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M6 3v6m0 0a3 3 0 103 3V9m-3 3a3 3 0 00-3 3m12-9v6m0 0a3 3 0 103 3V9m-3 3a3 3 0 01-3 3"/>
      </svg>
      <span class="font-semibold text-slate-600">{p.direct_fork_count}</span>
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
      </svg>
      <span class="font-semibold text-slate-600">{commentCount}</span>
    </span>
    <span class="ml-auto text-[10px]">{timeAgo(p.created_at)}</span>
  </div>
</a>
