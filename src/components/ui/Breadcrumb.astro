---
export interface Props {
  items: { label: string; href?: string }[]
}

const { items } = Astro.props
---
<div class="flex items-center gap-2 text-sm text-slate-500">
  {items.map((item, i) => (
    <>
      {i > 0 && (
        <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      )}
      {item.href ? (
        <a href={item.href} class="hover:text-slate-700 transition-colors">{item.label}</a>
      ) : (
        <span class="font-semibold text-slate-900">{item.label}</span>
      )}
    </>
  ))}
</div>
