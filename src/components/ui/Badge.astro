---
export interface Props {
  variant?: 'default' | 'success' | 'warning' | 'error' | 'info' | 'available' | 'partial' | 'missing' | 'incompatible'
  class?: string
}

const { variant = 'default', class: className = '' } = Astro.props

const variantClasses: Record<string, string> = {
  default:       'bg-slate-100 text-slate-700',
  success:       'bg-emerald-100 text-emerald-700',
  warning:       'bg-amber-100 text-amber-700',
  error:         'bg-red-100 text-red-700',
  info:          'bg-brand-100 text-brand-700',
  available:     'bg-emerald-100 text-emerald-700',
  partial:       'bg-amber-100 text-amber-700',
  missing:       'bg-red-100 text-red-700',
  incompatible:  'bg-orange-100 text-orange-700',
}

const classes = `inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${variantClasses[variant] ?? variantClasses.default} ${className}`
---
<span class={classes}>
  <slot />
</span>
