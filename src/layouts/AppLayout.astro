---
import BaseLayout from './BaseLayout.astro'

export interface Props {
  title?: string
  description?: string
  activeTab?: 'home' | 'inventory' | 'projects' | 'community'
}
const { title, description, activeTab } = Astro.props

function tabClass(tab: string) {
  return activeTab === tab
    ? 'flex flex-col items-center gap-0.5 flex-1 py-2 text-brand-600'
    : 'flex flex-col items-center gap-0.5 flex-1 py-2 text-slate-400'
}
---
<BaseLayout title={title} description={description}>
  <div class="flex flex-col h-full max-w-lg mx-auto relative">
    <!-- Main content -->
    <main class="flex-1 overflow-y-auto pb-20">
      <slot />
    </main>

    <!-- Bottom Navigation -->
    <nav class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-lg bg-white border-t border-slate-100 z-50 pb-safe">
      <div class="flex items-center px-2 pt-2 pb-6">
        <a href="/" class={tabClass('home')}>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
          </svg>
          <span style="font-size:10px; font-weight:500;">Inicio</span>
        </a>
        <a href="/inventory" class={tabClass('inventory')}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/>
            <path d="M16 3H8a2 2 0 00-2 2v2h12V5a2 2 0 00-2-2z"/>
          </svg>
          <span style="font-size:10px; font-weight:500;">Inventario</span>
        </a>
        <a href="/projects" class={tabClass('projects')}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span style="font-size:10px; font-weight:500;">Proyectos</span>
        </a>
        <a href="/community" class={tabClass('community')}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/>
          </svg>
          <span style="font-size:10px; font-weight:500;">Comunidad</span>
        </a>
      </div>
    </nav>
  </div>
</BaseLayout>
