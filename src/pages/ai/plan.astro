---
import AppLayout from '../../layouts/AppLayout.astro'
import PlanRefinement from '../../components/islands/PlanRefinement'
---

<AppLayout title="Nuevo proyecto" activeTab="projects">

  <!-- ── Mobile ─────────────────────────────────────────────────────────── -->
  <div class="px-4 pt-6 pb-8 lg:hidden">
    <div class="mb-6">
      <h1 class="text-xl font-bold text-slate-900 mb-1">Planificar proyecto</h1>
      <p class="text-sm text-slate-500">Describe lo que quieres construir y la IA generará un BOM.</p>
    </div>
    <PlanRefinement mode="plan" client:load />
  </div>

  <!-- ── Desktop topbar ──────────────────────────────────────────────────── -->
  <Fragment slot="topbar">
    <div class="flex items-center gap-2 text-sm text-slate-500">
      <a href="/projects" class="hover:text-slate-700 transition-colors">Proyectos</a>
      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M9 18l6-6-6-6"/>
      </svg>
      <span class="font-semibold text-slate-900">Nuevo proyecto</span>
    </div>
  </Fragment>

  <!-- ── Desktop main ────────────────────────────────────────────────────── -->
  <Fragment slot="desktop-main">
    <div class="max-w-2xl mx-auto">
      <div class="mb-6">
        <h1 class="text-xl font-bold text-slate-900 mb-1">Planificar proyecto</h1>
        <p class="text-sm text-slate-500">Describe lo que quieres construir y la IA generará un BOM completo cruzado con tu inventario.</p>
      </div>
      <PlanRefinement mode="plan" client:load />
    </div>
  </Fragment>

</AppLayout>
