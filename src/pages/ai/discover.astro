---
import AppLayout from '../../layouts/AppLayout.astro'
import Breadcrumb from '../../components/ui/Breadcrumb.astro'
import PlanRefinement from '../../components/islands/PlanRefinement'
---

<AppLayout title="Descubrir proyectos" activeTab="projects">

  <!-- ── Mobile ─────────────────────────────────────────────────────────── -->
  <div class="px-4 pt-6 pb-8 lg:hidden">
    <div class="mb-6">
      <h1 class="text-xl font-bold text-slate-900 mb-1">¿Qué puedo construir?</h1>
      <p class="text-sm text-slate-500">La IA analiza tu inventario y sugiere proyectos viables.</p>
    </div>
    <PlanRefinement mode="discover" client:load />
  </div>

  <!-- ── Desktop topbar ──────────────────────────────────────────────────── -->
  <Fragment slot="topbar">
    <Breadcrumb items={[{ label: 'Proyectos', href: '/projects' }, { label: 'Descubrir proyectos' }]} />
  </Fragment>

  <!-- ── Desktop main ────────────────────────────────────────────────────── -->
  <Fragment slot="desktop-main">
    <div class="max-w-2xl mx-auto">
      <div class="mb-6">
        <h1 class="text-xl font-bold text-slate-900 mb-1">¿Qué puedo construir?</h1>
        <p class="text-sm text-slate-500">La IA analiza tu inventario y sugiere proyectos viables ordenados por disponibilidad de componentes.</p>
      </div>
      <PlanRefinement mode="discover" client:load />
    </div>
  </Fragment>

</AppLayout>
