---
import AppLayout from '../../layouts/AppLayout.astro'
import EmptyState from '../../components/ui/EmptyState.astro'
import LocationTree from '../../components/islands/LocationTree'
import { createSupabaseServerClient } from '../../lib/supabase'

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: locations } = await supabase
  .from('locations')
  .select('*')
  .order('name')

const { data: allStock } = await supabase.from('stock').select('location_id')
const stockCounts: Record<string, number> = {}
for (const s of allStock ?? []) {
  if (s.location_id) {
    stockCounts[s.location_id] = (stockCounts[s.location_id] ?? 0) + 1
  }
}
---
<AppLayout title="Ubicaciones" activeTab="locations">
  <div class="px-4 pt-6 pb-4">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-xl font-bold text-slate-900">Ubicaciones</h1>
    </div>

    {(!locations || locations.length === 0) ? (
      <EmptyState
        title="Sin ubicaciones"
        description="Crea ubicaciones para organizar físicamente tus componentes"
        icon="📍"
      />
    ) : (
      <LocationTree locations={locations} stockCounts={stockCounts} client:load />
    )}
  </div>
</AppLayout>
