---
import AppLayout from '../../layouts/AppLayout.astro'
import BackButton from '../../components/ui/BackButton.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import QRLabel from '../../components/islands/QRLabel'
import LocationManager from '../../components/islands/LocationManager'
import { createSupabaseServerClient } from '../../lib/supabase'

const { id } = Astro.params
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: location } = await supabase.from('locations').select('*').eq('id', id!).single()
if (!location) return Astro.redirect('/locations')

const { data: stockItems } = await supabase
  .from('stock')
  .select('*, component:components(*)')
  .eq('location_id', id!)

const stockCount = stockItems?.length ?? 0

const { data: children } = await supabase
  .from('locations')
  .select('id, name, qr_code')
  .eq('parent_id', id!)
  .order('name')

const { data: parent } = location.parent_id
  ? await supabase.from('locations').select('id, name').eq('id', location.parent_id).single()
  : { data: null }
---
<AppLayout title={location.name} activeTab="locations">

  <!-- ─── Topbar (desktop) ──────────────────────────────────────────────── -->
  <Fragment slot="topbar">
    <div class="flex items-center gap-2 text-sm text-slate-500">
      <a href="/locations" class="hover:text-slate-700">Ubicaciones</a>
      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
      {parent && (
        <>
          <a href={`/locations/${parent.id}`} class="hover:text-slate-700">{parent.name}</a>
          <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </>
      )}
      <span class="font-semibold text-slate-900">{location.name}</span>
    </div>
    <div class="ml-auto"></div>
  </Fragment>

  <!-- ─── Desktop main ──────────────────────────────────────────────────── -->
  <Fragment slot="desktop-main">
    <div class="grid grid-cols-3 gap-6">

      <!-- Left column: components -->
      <div class="col-span-2 space-y-4">
        <div class="flex items-center gap-3 mb-2">
          <LocationManager locationId={location.id} name={location.name} stockCount={stockCount} client:load />
        </div>

        <h3 class="text-sm font-semibold text-slate-700">
          Componentes ({stockCount})
        </h3>
        <div class="space-y-2">
          {stockItems?.map(item => (
            <Card href={`/inventory/${item.id}`}>
              <div class="p-3 flex items-center gap-3">
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-medium text-slate-900 truncate">{item.component?.name}</div>
                  <div class="text-xs text-slate-400">{item.component?.sku}</div>
                </div>
                <Badge variant="info">{item.quantity} uds.</Badge>
              </div>
            </Card>
          ))}
          {stockCount === 0 && (
            <p class="text-sm text-slate-400 py-4">No hay componentes en esta ubicación.</p>
          )}
        </div>
      </div>

      <!-- Right column: QR + info + sub-locations -->
      <div class="space-y-4">
        <QRLabel qrCode={location.qr_code} locationName={location.name} client:load />

        {children && children.length > 0 && (
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4">
            <h3 class="text-sm font-semibold text-slate-700 mb-3">Sub-ubicaciones</h3>
            <div class="space-y-2">
              {children.map(child => (
                <a href={`/locations/${child.id}`} class="flex items-center gap-2 p-2 rounded-xl hover:bg-slate-50 transition-colors">
                  <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />
                  </svg>
                  <span class="text-sm text-slate-700 truncate">{child.name}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

    </div>
  </Fragment>

  <!-- ─── Mobile layout ─────────────────────────────────────────────────── -->
  <div class="px-4 pt-6 pb-8">
    <div class="flex items-center gap-3 mb-6">
      <BackButton href="/locations" />
      <LocationManager locationId={location.id} name={location.name} stockCount={stockCount} client:load />
    </div>

    {children && children.length > 0 && (
      <div class="mb-6">
        <h2 class="text-sm font-semibold text-slate-700 mb-3">Sub-ubicaciones</h2>
        <div class="grid grid-cols-2 gap-2">
          {children.map(child => (
            <a href={`/locations/${child.id}`} class="flex items-center gap-2 bg-white rounded-xl border border-slate-100 p-3 hover:bg-slate-50 transition-colors">
              <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />
              </svg>
              <span class="text-sm text-slate-700 truncate">{child.name}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <h2 class="text-sm font-semibold text-slate-700 mb-3">
      Componentes ({stockCount})
    </h2>
    <div class="space-y-2">
      {stockItems?.map(item => (
        <Card href={`/inventory/${item.id}`}>
          <div class="p-3 flex items-center gap-3">
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-slate-900 truncate">{item.component?.name}</div>
              <div class="text-xs text-slate-400">{item.component?.sku}</div>
            </div>
            <Badge variant="info">{item.quantity} uds.</Badge>
          </div>
        </Card>
      ))}
      {stockCount === 0 && (
        <p class="text-sm text-slate-400 py-4">No hay componentes en esta ubicación.</p>
      )}
    </div>

    <div class="mt-6">
      <QRLabel qrCode={location.qr_code} locationName={location.name} client:load />
    </div>
  </div>

</AppLayout>
