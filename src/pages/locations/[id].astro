---
import AppLayout from '../../layouts/AppLayout.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import QRLabel from '../../components/islands/QRLabel'
import { createSupabaseServerClient } from '../../lib/supabase'

const { id } = Astro.params
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: location } = await supabase.from('locations').select('*').eq('id', id!).single()
if (!location) return Astro.redirect('/locations')

const { data: stockItems } = await supabase
  .from('stock')
  .select('*, component:components(*)')
  .eq('location_id', id!)
---
<AppLayout title={location.name} activeTab="locations">
  <div class="px-4 pt-6 pb-8">
    <div class="flex items-center gap-3 mb-6">
      <a href="/locations" class="w-9 h-9 flex items-center justify-center rounded-xl hover:bg-slate-100 transition-colors">
        <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="text-xl font-bold text-slate-900">{location.name}</h1>
    </div>

    <div class="mb-4">
      <QRLabel qrCode={location.qr_code} locationName={location.name} client:load />
    </div>

    <h2 class="text-sm font-semibold text-slate-700 mb-3">
      Componentes ({stockItems?.length ?? 0})
    </h2>
    <div class="space-y-2">
      {stockItems?.map(item => (
        <Card href={`/inventory/${item.id}`}>
          <div class="p-3 flex items-center gap-3">
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-slate-900 truncate">{item.component?.name}</div>
              <div class="text-xs text-slate-400">{item.component?.sku}</div>
            </div>
            <Badge variant="info">{item.quantity} uds.</Badge>
          </div>
        </Card>
      ))}
    </div>
  </div>
</AppLayout>
