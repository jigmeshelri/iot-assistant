---
import AppLayout from '../../layouts/AppLayout.astro'
import Badge from '../../components/ui/Badge.astro'
import BOMTable from '../../components/islands/BOMTable'
import ForkButton from '../../components/islands/ForkButton'
import CommentThread from '../../components/islands/CommentThread'
import { createSupabaseServerClient } from '../../lib/supabase'

const { id } = Astro.params
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: project } = await supabase.from('projects').select('*').eq('id', id!).eq('is_public', true).single()
if (!project) return Astro.redirect('/community')

const { data: bom } = await supabase.from('project_bom').select('*, component:components(*)').eq('project_id', id!)
---
<AppLayout title={project.title} activeTab="community">
  <div class="px-4 pt-6 pb-8">
    <div class="flex items-center gap-3 mb-4">
      <a href="/community" class="w-9 h-9 flex items-center justify-center rounded-xl hover:bg-slate-100">
        <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="text-lg font-bold text-slate-900 truncate flex-1">{project.title}</h1>
      <ForkButton projectId={id!} forkCount={project.direct_fork_count} client:load />
    </div>

    {project.description && <p class="text-sm text-slate-600 mb-4 leading-relaxed">{project.description}</p>}

    <div class="flex flex-wrap gap-2 mb-4">
      {project.tags?.map((tag: string) => (
        <span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded-full text-xs">{tag}</span>
      ))}
    </div>

    {bom && bom.length > 0 && (
      <div class="mb-6">
        <h2 class="text-sm font-semibold text-slate-700 mb-2">Materiales</h2>
        <BOMTable items={bom} client:load />
      </div>
    )}

    <h2 class="text-sm font-semibold text-slate-700 mb-2">Comentarios</h2>
    <CommentThread projectId={id!} client:load />
  </div>
</AppLayout>
