---
import AppLayout from '../../layouts/AppLayout.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import EmptyState from '../../components/ui/EmptyState.astro'
import { createSupabaseServerClient } from '../../lib/supabase'

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: projects } = await supabase
  .from('projects')
  .select('*, comments:project_comments(count)')
  .eq('is_public', true)
  .order('direct_fork_count', { ascending: false })
  .limit(50)
---
<AppLayout title="Comunidad" activeTab="community">
  <div class="px-4 pt-6 pb-4">
    <h1 class="text-xl font-bold text-slate-900 mb-4">Comunidad</h1>

    {(!projects || projects.length === 0) ? (
      <EmptyState
        title="Sin proyectos públicos"
        description="Sé el primero en compartir un proyecto con la comunidad"
        icon="🌍"
      />
    ) : (
      <div class="space-y-3">
        {projects.map(p => (
          <Card href={`/community/${p.id}`}>
            <div class="p-4">
              <div class="flex items-start justify-between gap-2 mb-2">
                <h2 class="text-sm font-semibold text-slate-900 leading-tight">{p.title}</h2>
                <Badge variant="default">{p.project_type}</Badge>
              </div>
              {p.description && <p class="text-xs text-slate-500 line-clamp-2 mb-2">{p.description}</p>}
              <div class="flex items-center gap-3 text-xs text-slate-400">
                <span>🍴 {p.direct_fork_count}</span>
                <span>💬 {p.comments?.[0]?.count ?? 0}</span>
                {p.difficulty && <Badge variant="default">{p.difficulty}</Badge>}
              </div>
            </div>
          </Card>
        ))}
      </div>
    )}
  </div>
</AppLayout>
