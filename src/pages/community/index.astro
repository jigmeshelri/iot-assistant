---
import AppLayout from '../../layouts/AppLayout.astro'
import CommunityCard from '../../components/ui/CommunityCard.astro'
import EmptyState from '../../components/ui/EmptyState.astro'
import { createSupabaseServerClient } from '../../lib/supabase'

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: projects } = await supabase
  .from('projects')
  .select('*, comments:project_comments(count)')
  .eq('is_public', true)
  .order('direct_fork_count', { ascending: false })
  .limit(50)

const projectCount = projects?.length ?? 0
---
<AppLayout title="Comunidad" activeTab="community">

  <!-- ── Mobile ─────────────────────────────────────────────────────────── -->
  <div class="lg:hidden px-4 pt-6 pb-4">
    <h1 class="text-xl font-bold text-slate-900 mb-4">Comunidad</h1>

    {projectCount === 0 ? (
      <EmptyState
        title="Sin proyectos públicos"
        description="Sé el primero en compartir un proyecto con la comunidad"
        icon="🌍"
      />
    ) : (
      <div class="flex flex-col gap-3">
        {projects!.map(p => <CommunityCard project={p} />)}
      </div>
    )}
  </div>

  <!-- ── Desktop topbar ──────────────────────────────────────────────────── -->
  <Fragment slot="topbar">
    <h2 class="text-base font-bold text-slate-900 flex-1">Comunidad</h2>
    <span class="text-xs text-slate-400">{projectCount} {projectCount === 1 ? 'proyecto' : 'proyectos'}</span>
  </Fragment>

  <!-- ── Desktop main ────────────────────────────────────────────────────── -->
  <Fragment slot="desktop-main">
    {projectCount === 0 ? (
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-12 text-center">
        <EmptyState
          title="Sin proyectos públicos"
          description="Sé el primero en compartir un proyecto con la comunidad"
          icon="🌍"
        />
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        {projects!.map(p => <CommunityCard project={p} />)}
      </div>
    )}
  </Fragment>

</AppLayout>
