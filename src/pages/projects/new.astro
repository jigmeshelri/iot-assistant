---
import AppLayout from '../../layouts/AppLayout.astro'
import Breadcrumb from '../../components/ui/Breadcrumb.astro'
import ProjectForm from '../../components/islands/ProjectForm'
---

<AppLayout title="Nuevo proyecto" activeTab="projects">

  <!-- Mobile -->
  <div class="bg-white min-h-full lg:hidden">
    <div class="px-5 pt-3 pb-4 bg-white sticky top-0 z-10 border-b border-slate-50">
      <div class="flex items-center gap-2">
        <a href="/projects" class="w-8 h-8 rounded-lg flex items-center justify-center hover:bg-slate-100 transition-colors" aria-label="Volver a proyectos">
          <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </a>
        <h2 class="text-xl font-bold text-slate-900">Nuevo proyecto</h2>
      </div>
    </div>
    <div class="px-5 py-4">
      <ProjectForm client:load />
    </div>
  </div>

  <!-- Desktop topbar -->
  <Fragment slot="topbar">
    <Breadcrumb items={[{ label: 'Proyectos', href: '/projects' }, { label: 'Nuevo proyecto' }]} />
  </Fragment>

  <!-- Desktop main -->
  <Fragment slot="desktop-main">
    <div class="max-w-2xl mx-auto">
      <ProjectForm client:load />
    </div>
  </Fragment>

</AppLayout>
