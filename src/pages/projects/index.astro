---
import AppLayout from '../../layouts/AppLayout.astro'
import EmptyState from '../../components/ui/EmptyState.astro'
import Badge from '../../components/ui/Badge.astro'
import { createSupabaseServerClient } from '../../lib/supabase'

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: projects } = await supabase
  .from('projects')
  .select('*')
  .order('updated_at', { ascending: false })

const statusColor: Record<string, 'default' | 'success' | 'warning' | 'error' | 'info'> = {
  saved:       'default',
  in_progress: 'info',
  paused:      'warning',
  completed:   'success',
  abandoned:   'error',
}
const statusLabel: Record<string, string> = {
  saved:       'Guardado',
  in_progress: 'En curso',
  paused:      'Pausado',
  completed:   'Completado',
  abandoned:   'Abandonado',
}

const iconColors = [
  { bg: 'bg-amber-100',  text: 'text-amber-600'  },
  { bg: 'bg-violet-100', text: 'text-violet-600' },
  { bg: 'bg-green-100',  text: 'text-green-600'  },
  { bg: 'bg-brand-100',  text: 'text-brand-600'  },
  { bg: 'bg-rose-100',   text: 'text-rose-600'   },
]

const progressBarColor: Record<string, string> = {
  in_progress: 'bg-brand-500',
  paused:      'bg-violet-400',
  completed:   'bg-green-500',
  saved:       'bg-slate-300',
  abandoned:   'bg-slate-200',
}
---
<AppLayout title="Proyectos" activeTab="projects">
  <div class="bg-white min-h-full">

    <!-- Header -->
    <div class="px-5 pt-3 pb-4 bg-white sticky top-0 z-10 border-b border-slate-50">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-bold text-slate-900">Proyectos</h2>
        <a href="/ai/plan" class="w-10 h-10 bg-brand-600 rounded-xl flex items-center justify-center flex-shrink-0 hover:bg-brand-700 transition-colors" aria-label="Nuevo proyecto">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Lista -->
    {(!projects || projects.length === 0) ? (
      <div class="px-5 pt-4">
        <EmptyState
          title="Sin proyectos"
          description="Empieza a planificar tu primer proyecto con la ayuda de la IA"
          actionHref="/ai/discover"
          actionLabel="Descubrir proyectos"
          icon="🗂️"
        />
      </div>
    ) : (
      <div class="px-5 flex flex-col gap-2.5 py-4">
        {projects.map((p: any, i: number) => {
          const c = iconColors[i % iconColors.length]
          const pct: number = p.progress ?? 0
          const barColor = progressBarColor[p.status] ?? 'bg-slate-300'
          return (
            <a href={`/projects/${p.id}`} class="bg-white rounded-2xl p-3.5 flex items-center gap-3 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
              <div class={`w-9 h-9 rounded-xl ${c.bg} flex items-center justify-center flex-shrink-0`}>
                <svg class={`w-5 h-5 ${c.text}`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2 mb-1">
                  <p class="text-sm font-semibold text-slate-800 truncate">{p.title}</p>
                  <Badge variant={statusColor[p.status] ?? 'default'}>{statusLabel[p.status] ?? p.status}</Badge>
                </div>
                {p.description && (
                  <p class="text-xs text-slate-500 line-clamp-1 mb-1.5">{p.description}</p>
                )}
                <div class="flex items-center gap-2">
                  <div class="flex-1 bg-slate-100 rounded-full h-1.5">
                    <div class={`${barColor} h-1.5 rounded-full`} style={`width:${pct}%`}></div>
                  </div>
                  <span class="text-xs text-slate-400 flex-shrink-0">{pct}%</span>
                </div>
              </div>
            </a>
          )
        })}
      </div>
    )}
  </div>
</AppLayout>
