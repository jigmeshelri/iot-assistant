---
import AppLayout from '../../layouts/AppLayout.astro'
import Breadcrumb from '../../components/ui/Breadcrumb.astro'
import CameraCapture from '../../components/islands/CameraCapture'
---

<AppLayout title="Escanear componente" activeTab="scan">

  <!-- ── Mobile ─────────────────────────────────────────────────────────── -->
  <div class="px-4 pt-6 pb-8 lg:hidden">
    <div class="flex items-center gap-3 mb-6">
      <a href="/inventory" class="w-9 h-9 flex items-center justify-center rounded-xl hover:bg-slate-100 transition-colors">
        <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="text-xl font-bold text-slate-900">Añadir componente</h1>
    </div>
    <CameraCapture client:load />
  </div>

  <!-- ── Desktop topbar ──────────────────────────────────────────────────── -->
  <Fragment slot="topbar">
    <Breadcrumb items={[{ label: 'Inventario', href: '/inventory' }, { label: 'Escanear IA' }]} />
  </Fragment>

  <!-- ── Desktop main ────────────────────────────────────────────────────── -->
  <Fragment slot="desktop-main">
    <div class="max-w-2xl mx-auto">
      <div class="mb-6">
        <h1 class="text-xl font-bold text-slate-900 mb-1">Escanear componente</h1>
        <p class="text-sm text-slate-500">Fotografía una pieza y la IA la identificará automáticamente.</p>
      </div>
      <CameraCapture client:load />
    </div>
  </Fragment>

</AppLayout>
