---
import AppLayout from '../../layouts/AppLayout.astro'
import EmptyState from '../../components/ui/EmptyState.astro'
import { createSupabaseServerClient } from '../../lib/supabase'

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: stockItems } = await supabase
  .from('stock')
  .select('*, component:components(*), location:locations(name, parent:locations(name))')
  .order('updated_at', { ascending: false })

const categoryColors: Record<string, { bg: string; icon: string }> = {
  'Microcontrolador': { bg: 'bg-brand-50',  icon: 'text-brand-600'  },
  'Sensor':           { bg: 'bg-amber-50',  icon: 'text-amber-500'  },
  'Actuador':         { bg: 'bg-violet-50', icon: 'text-violet-500' },
  'Alimentación':     { bg: 'bg-green-50',  icon: 'text-green-500'  },
}

function qtyColor(qty: number) {
  return qty > 1 ? 'text-slate-900' : 'text-amber-500'
}
---
<AppLayout title="Inventario" activeTab="inventory">
  <div class="bg-white min-h-full">

    <!-- Header sticky -->
    <div class="px-5 pt-3 pb-3 bg-white sticky top-0 z-10">
      <h2 class="text-xl font-bold text-slate-900 mb-3">Inventario</h2>

      <!-- Buscador + botón añadir -->
      <div class="flex gap-2 mb-3">
        <div class="flex-1 flex items-center gap-2 bg-slate-100 rounded-xl px-3 py-2.5">
          <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
          </svg>
          <span class="text-sm text-slate-400">Buscar componentes...</span>
        </div>
        <a
          href="/inventory/new"
          class="w-10 h-10 bg-brand-600 rounded-xl flex items-center justify-center flex-shrink-0 hover:bg-brand-700 transition-colors"
          aria-label="Añadir componente"
        >
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
        </a>
      </div>

      <!-- Filtros -->
      <div class="flex gap-2 overflow-x-auto pb-0.5 scrollbar-hide">
        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-brand-600 text-white flex-shrink-0 cursor-pointer">Todos</span>
        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 flex-shrink-0 cursor-pointer">MCU</span>
        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 flex-shrink-0 cursor-pointer">Sensores</span>
        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 flex-shrink-0 cursor-pointer">Módulos</span>
        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 flex-shrink-0 cursor-pointer">Pasivos</span>
      </div>
    </div>

    <!-- Lista -->
    {(!stockItems || stockItems.length === 0) ? (
      <div class="px-5 pt-4">
        <EmptyState
          title="Sin componentes"
          description="Añade tu primer componente al inventario"
          actionHref="/inventory/new"
          actionLabel="Añadir componente"
          icon="📦"
        />
      </div>
    ) : (
      <div class="px-5 flex flex-col gap-2.5 pb-4 pt-3">
        {stockItems.map((item: any) => {
          const cat = item.component?.category ?? ''
          const colors = categoryColors[cat] ?? { bg: 'bg-slate-100', icon: 'text-slate-500' }
          const locName = item.location?.name
          const parentName = item.location?.parent?.name
          const locStr = locName ? (parentName ? `${parentName} → ${locName}` : locName) : null
          const qty: number = item.quantity ?? 0
          return (
            <a href={`/inventory/${item.id}`} class="bg-white rounded-2xl p-3.5 flex items-center gap-3 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
              <div class={`w-12 h-12 ${colors.bg} rounded-xl flex items-center justify-center flex-shrink-0`}>
                {item.component?.image_url ? (
                  <img src={item.component.image_url} alt={item.component?.name} class="w-10 h-10 object-contain rounded-lg" />
                ) : (
                  <svg class={`w-6 h-6 ${colors.icon}`} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <rect x="4" y="4" width="16" height="16" rx="2"/>
                    <rect x="9" y="9" width="6" height="6"/>
                    <path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/>
                  </svg>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-slate-800 truncate">{item.component?.name ?? 'Componente desconocido'}</p>
                <p class="text-xs text-slate-400 truncate">
                  {cat}
                  {item.component?.sku ? ` · ${item.component.sku}` : ''}
                </p>
                {locStr && (
                  <p class="text-xs text-slate-400 mt-0.5">📦 {locStr}</p>
                )}
              </div>
              <div class="text-right flex-shrink-0">
                <div class={`text-lg font-bold ${qtyColor(qty)}`}>{qty}</div>
                <div class="text-xs text-slate-400">unid.</div>
              </div>
            </a>
          )
        })}
      </div>
    )}
  </div>
</AppLayout>
