---
import AppLayout from '../layouts/AppLayout.astro'
import { createSupabaseServerClient } from '../lib/supabase'

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request)
const { data: { user } } = await supabase.auth.getUser()

// Fetch summary counts in parallel
const [stockRes, projectsRes, locationsRes] = await Promise.all([
  supabase.from('stock').select('id', { count: 'exact', head: true }),
  supabase.from('projects').select('id', { count: 'exact', head: true }).eq('status', 'in_progress'),
  supabase.from('locations').select('id', { count: 'exact', head: true }),
])

const stats = [
  { label: 'Componentes en stock', value: stockRes.count ?? 0, href: '/inventory', color: 'brand' },
  { label: 'Proyectos activos', value: projectsRes.count ?? 0, href: '/projects', color: 'amber' },
  { label: 'Ubicaciones', value: locationsRes.count ?? 0, href: '/locations', color: 'slate' },
]
---
<AppLayout title="Dashboard" activeTab="inventory">
  <div class="px-4 pt-6 pb-4">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Dashboard</h1>
        <p class="text-sm text-slate-500">Bienvenido, {user?.email?.split('@')[0]}</p>
      </div>
      <div class="w-10 h-10 bg-brand-100 rounded-full flex items-center justify-center">
        <span class="text-brand-700 font-semibold text-sm">
          {user?.email?.[0]?.toUpperCase() ?? '?'}
        </span>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-3 mb-6">
      {stats.map(s => (
        <a href={s.href} class="bg-white rounded-2xl p-4 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <div class="text-2xl font-bold text-slate-900">{s.value}</div>
          <div class="text-xs text-slate-500 mt-1 leading-tight">{s.label}</div>
        </a>
      ))}
    </div>

    <!-- Quick actions -->
    <h2 class="text-sm font-semibold text-slate-700 mb-3">Acciones rápidas</h2>
    <div class="grid grid-cols-2 gap-3">
      {[
        { href: '/inventory/new', label: 'Añadir componente', icon: '➕', desc: 'Manual o con cámara' },
        { href: '/ai/discover', label: '¿Qué puedo construir?', icon: '✨', desc: 'Sugerencias con IA' },
        { href: '/locations', label: 'Mis ubicaciones', icon: '📍', desc: 'Árbol de almacenamiento' },
        { href: '/ai/plan', label: 'Planificar proyecto', icon: '🗺️', desc: 'BOM con IA' },
      ].map(a => (
        <a href={a.href} class="bg-white rounded-2xl p-4 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">{a.icon}</div>
          <div class="text-sm font-medium text-slate-800">{a.label}</div>
          <div class="text-xs text-slate-400 mt-1">{a.desc}</div>
        </a>
      ))}
    </div>
  </div>
</AppLayout>
